# AI Recommendation Service Configuration

FLASK_ENV=development
FLASK_DEBUG=true

# Server
FLASK_APP=app.py
SERVER_PORT=5000

# Model Configuration
# Options: all-MiniLM-L6-v2 (small), all-mpnet-base-v2 (medium), all-roberta-large-v1 (large)
MODEL_NAME=all-MiniLM-L6-v2

# CORS Settings
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
